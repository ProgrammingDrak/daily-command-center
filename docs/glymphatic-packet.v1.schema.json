{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "glymphatic_packet.v1",
  "title": "Glymphatic deep-sweep packet (v1)",
  "description": "Payload POSTed to /api/dcc/deep-sweep/ingest by the brain's glymphatic collector. The brief 'pages' array drives the multi-page DCC Brief. Decisions made on the front page are written back to day-state glymphatic_brief.decisions via /api/dcc/brief/decision and consumed by morning scheduling.",
  "type": "object",
  "required": ["date", "source", "generated_at"],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "source": { "type": "string", "description": "Packet author, e.g. glymphatic-nightly" },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },
    "suggested_tasks": { "type": "array", "items": { "$ref": "#/$defs/task" } },
    "lessons": { "type": "array" },
    "disregarded": { "type": "array" },
    "retro": { "type": ["object", "null"] },
    "open_items": { "type": "array" },
    "meetings": { "type": "array" },
    "source_health": { "type": "array" },
    "pages": {
      "type": "array",
      "description": "Ordered Brief pages. Known ids: day-review, canvas, front, actual-vs-planned, step-back, personal-bible, process. The 'day-review' page (usually first on the nightly brief) is the end-of-day 'what I did today' reconstruction; its items[] carry Approve (log-done) + push-to-tomorrow controls. The 'canvas' page is the agent-authored expressive view; its canvas_html renders inside a sandboxed iframe. Unknown ids render as raw JSON.",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "summary": { "type": "string" },
          "canvas_html": { "type": "string", "description": "canvas page: self-contained HTML document rendered in a sandboxed iframe (no same-origin). Display-only; carries no actionable controls." },
          "height": { "type": "integer", "description": "canvas page: iframe height in px (default 1180)" },
          "metrics": { "type": "array", "items": { "type": "object", "properties": { "label": { "type": "string" }, "value": {} } } },

          "done_today": {
            "type": "array",
            "description": "front page section 1: completed work grouped by project/category",
            "items": {
              "type": "object",
              "required": ["project", "items"],
              "properties": {
                "project": { "type": "string" },
                "items": { "type": "array", "items": { "type": "object", "required": ["title"], "properties": { "title": { "type": "string" }, "detail": { "type": "string" } } } }
              }
            }
          },
          "tomorrow": {
            "type": "array",
            "description": "front page section 2: proposed itinerary; each row gets accept/move/backlog/drop controls",
            "items": { "$ref": "#/$defs/task" }
          },

          "rows": { "type": "array", "description": "actual-vs-planned rows: {title, status, meta}" },

          "habits": { "type": "array", "description": "step-back: {habit, cadence, status}" },
          "projects": { "type": "array", "description": "step-back: {name, status, milestone}" },
          "upcoming": { "type": "array", "description": "step-back: {when, title}" },
          "note": { "type": "string" },

          "source": { "type": "string", "description": "personal-bible: provenance line" },
          "question": { "type": "string", "description": "personal-bible: open question of the day" },
          "sections": { "type": "array", "description": "personal-bible: {heading, body}" },

          "proof_of_work": { "type": "array", "description": "process: {label, value}" },
          "notes": { "type": "array", "items": { "type": "string" } },

          "items": {
            "type": "array",
            "description": "day-review page: reconstructed 'did today' items. Each renders with editable time/duration + Approve (POST /api/dcc/brief/log-done, logs a COMPLETED task and banks points) and per-follow-up Push-to-tomorrow (POST /api/dcc/brief/push-next). Idempotent on idempotency_key.",
            "items": { "$ref": "#/$defs/did_item" }
          }
        }
      }
    }
  },
  "$defs": {
    "did_item": {
      "type": "object",
      "required": ["id", "title", "idempotency_key"],
      "properties": {
        "id": { "type": "string", "description": "stable within the day (drives approved/pushed UI state)" },
        "title": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "start": { "type": "string", "description": "HH:MM ET, estimated time-of-occurrence; editable before Approve" },
        "duration": { "type": "integer", "description": "minutes; editable before Approve" },
        "reason": { "type": "string" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "evidence": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string" }, "label": { "type": "string" }, "ref": { "type": "string" } } } },
        "idempotency_key": { "type": "string" },
        "approvable": { "type": "boolean", "description": "default true; false = a follow-ups-only bucket (e.g. Loose ends), no Approve/time controls" },
        "followups": {
          "type": "array",
          "description": "undone portions; each gets a Push-to-tomorrow button",
          "items": {
            "type": "object",
            "required": ["id", "title"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "duration": { "type": "integer" },
              "idempotency_key": { "type": "string" }
            }
          }
        }
      }
    },
    "task": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "suggested_start": { "type": "string", "description": "HH:MM" },
        "recommended_start": { "type": "string", "description": "HH:MM (suggested_tasks alias)" },
        "duration": { "type": "integer", "description": "minutes" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "project": { "type": "string" },
        "reason": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string" }
      }
    }
  }
}
