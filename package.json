{
  "name": "daily-command-center",
  "version": "1.0.0",
  "description": "Drake's Daily Command Center — standalone Express dashboard",
  "main": "server.js",
  "scripts": {
    "check:db": "node scripts/check-db.js",
    "db:refresh-local": "node scripts/refresh-local-db.js",
    "db:refresh-local:mac": "bash scripts/refresh-local-db.sh",
    "db:schedule-local-refresh": "powershell -ExecutionPolicy Bypass -File scripts/refresh-local-db.ps1 -InstallDailyTask",
    "brief:materialize": "node scripts/morning-brief-materializer.js",
    "triage:ingest": "node scripts/triage-check-ingest.js",
    "sweep:check": "node scripts/sweep-suite-check.js",
    "ship": "node scripts/ship-pr.js",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "npm run check:db && node pg-schema.js && node server.js",
    "dev": "npm run start",
    "start:prod": "node pg-schema.js && node server.js",
    "schema": "node pg-schema.js",
    "backup": "bash scripts/db-backup.sh",
    "smoke": "node scripts/smoke.mjs",
    "smoke:ci": "node scripts/smoke-ci.mjs",
    "start:render": "npm run check:db && node pg-schema.js && node server.js"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1094.0",
    "@aws-sdk/s3-request-presigner": "^3.1094.0",
    "bcryptjs": "^3.0.3",
    "chokidar": "^3.6.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.0",
    "drake-auth": "github:ProgrammingDrak/drake-auth#v0.1.1",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "multer": "^2.2.0",
    "pg": "^8.13.0",
    "simple-git": "^3.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.3.0"
  }
}
