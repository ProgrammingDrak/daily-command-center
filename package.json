{
  "name": "daily-command-center",
  "version": "1.0.0",
  "description": "Drake's Daily Command Center — standalone Express dashboard",
  "main": "server.js",
  "scripts": {
    "check:db": "node scripts/check-db.js",
    "db:refresh-local": "powershell -ExecutionPolicy Bypass -File scripts/refresh-local-db.ps1",
    "db:schedule-local-refresh": "powershell -ExecutionPolicy Bypass -File scripts/refresh-local-db.ps1 -InstallDailyTask",
    "start": "npm run check:db && node pg-schema.js && node server.js",
    "dev": "npm run start",
    "start:render": "node pg-schema.js && node server.js",
    "schema": "node pg-schema.js",
    "migrate-data": "node sqlite-to-pg.js",
    "backup": "bash scripts/db-backup.sh"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "pg": "^8.13.0",
    "simple-git": "^3.25.0"
  }
}
