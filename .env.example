# Copy to .env for local development. Do not commit real secrets.

# Required for local sync/persistence. Use the same Postgres target as the
# deployed service, or a local Postgres database with pg-schema.js applied.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# Optional local login bypass. Leave off in production.
DCC_LOCAL_AUTH=1
SEED_USERNAME=drake
SEED_PASSWORD=clever123

# Optional local overrides.
PORT=8090
DCC_TIME_ZONE=America/New_York
