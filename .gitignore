node_modules/
.env
.env.local

# Local AI tool settings (machine-specific permissions, never shared)
.claude/settings.local.json

# Transient server logs (never commit)
.codex-server.err.log
.codex-server.out.log
*.codex-server.*.log

# Data directory — tracked by default; ignore specific local-only paths
data/.session-secret
data/.sync-queue.json
data/.vault-index.json

# SQLite WAL files (transient, never commit)
data/blocks.db-shm
data/blocks.db-wal
data/postgres/
data/postgres.log

# Credentials (never commit)
data/gcal-credentials.json
data/gcal-tokens.json

# Brain subdirs: archive/ is tracked for cross-machine review; the rest is local
data/brain/recent/
data/brain/engrams/
.gstack/
supabase/.temp/

# Local Git worktrees for this repo
.worktrees/

# Vault — owned by its own git repo, never tracked here
vault/

# pg_dump output (created by scripts/db-backup.sh)
backups/


# Legacy SQLite store — superseded by Postgres; contained live secrets, never track
data/blocks.db

# Transient agent artifacts (never commit)
.codex-*.log
.codex-*.patch
tmp-*.json
